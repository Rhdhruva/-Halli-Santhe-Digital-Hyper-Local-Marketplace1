<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.HalliSanthe" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/amber_accent</item>
        <item name="colorOnSecondary">@color/brown_dark</item>
        <item name="android:colorBackground">@color/bg_surface</item>
        <item name="colorError">@color/error_red</item>
        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.HalliSanthe.Splash" parent="Theme.HalliSanthe">
        <item name="android:windowBackground">@color/bg_splash</item>
        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="ShapeAppearance.Rounded12" parent="ShapeAppearance.MaterialComponents">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

</resources>

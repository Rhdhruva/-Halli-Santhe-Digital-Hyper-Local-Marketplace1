<?xml version="1.0" encoding="utf-8"?>
<!--
    To use Noto Serif, add the font files to res/font/ or use Google Fonts:
    https://fonts.google.com/specimen/Noto+Serif

    For now this uses the system serif fallback.
    Add the actual .ttf files as:
      res/font/noto_serif.ttf
      res/font/noto_serif_bold.ttf
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <font
        android:font="@font/noto_serif_regular"
        android:fontStyle="normal"
        android:fontWeight="400"
        app:font="@font/noto_serif_regular"
        app:fontStyle="normal"
        app:fontWeight="400" />

    <font
        android:font="@font/noto_serif_bold"
        android:fontStyle="normal"
        android:fontWeight="700"
        app:font="@font/noto_serif_bold"
        app:fontStyle="normal"
        app:fontWeight="700" />

</font-family>
